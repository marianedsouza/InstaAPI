# DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/insta_api"
SHADOW_DATABASE_URL="postgresql://user:password@localhost:5432/insta_api_shadow"

# REDIS
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRATION="7d"

# GEMINI AI
GEMINI_API_KEY="your-gemini-api-key"

# APIFY
APIFY_API_TOKEN="your_apify_api_token"
APIFY_INSTAGRAM_PROFILE_ACTOR_ID="apify/instagram-profile-scraper"
APIFY_INSTAGRAM_POSTS_ACTOR_ID="apify/instagram-post-scraper"

# BACKEND
BACKEND_PORT=3001
BACKEND_URL="http://localhost:3001"
NODE_ENV="development"

# FRONTEND
FRONTEND_PORT=3000
FRONTEND_URL="http://localhost:3000"

# CORS
CORS_ORIGIN="http://localhost:3000"

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# LOGGING
LOG_LEVEL="info"

# AWS (optional for future S3 integration)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""

# ENCRYPTION
ENCRYPTION_KEY="your-encryption-key-change-in-production"
